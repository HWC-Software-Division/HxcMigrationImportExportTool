<Window x:Class="HxcMigrationImportExportTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HXC Import/Expoty K13 → Xperience Tool"
        Height="Auto"
        Width="750">

    <Grid Margin="10" VerticalAlignment="Top">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Select ZIP -->
            <RowDefinition Height="Auto"/>  <!-- Summary Count -->
            <RowDefinition Height="300"/>   <!-- Tabs List -->
            <RowDefinition Height="200"/>   <!-- Dynamic detail -->
            <RowDefinition Height="100"/>  <!-- Button Action -->
        </Grid.RowDefinitions>

        <!-- Select ZIP -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">

            <Button Name="btnSelectZip"
                    Width="120"
                    Height="30"
                    Click="BtnSelectZip_Click">
                Select ZIP
            </Button>

            <TextBox Name="txtZipFile"
                     Margin="10,0,0,0"
                     Width="600"/>

        </StackPanel>

        <!-- Summary Count (PageType, ResourceString, CustomTable) -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10">
            <TextBlock Text="PageType : "/>
            <TextBlock Name="txtPageTypeCount"/>

            <TextBlock Text="    ResourceString : "/>
            <TextBlock Name="txtResourceCount"/>

            <TextBlock Text="    CustomTable : "/>
            <TextBlock Name="txtCustomCount"/>
        </StackPanel>

        <!-- Tabs List -->
        <TabControl Grid.Row="2" SelectionChanged="TabControl_SelectionChanged">

            <TabItem Header="PageType">
                <DataGrid Name="gridPageTypes"
                          AutoGenerateColumns="False"
                          SelectionChanged="GridPageTypes_SelectionChanged">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ClassName" Binding="{Binding ClassName}" Width="200"/>
                        <DataGridTextColumn Header="DisplayName" Binding="{Binding DisplayName}" Width="200"/>
                        <DataGridTextColumn Header="TableName" Binding="{Binding TableName}" Width="200"/>
                        <DataGridTextColumn Header="Field Count" Binding="{Binding Fields.Count}" Width="150"/>
                    </DataGrid.Columns>
                    
                </DataGrid>
            </TabItem>

            <TabItem Header="ResourceString">
                <DataGrid Name="gridResource"
                          AutoGenerateColumns="True"
                          SelectionChanged="GridResource_SelectionChanged"/>
            </TabItem>

            <TabItem Header="CustomTable">
                <DataGrid Name="gridCustom"
                          AutoGenerateColumns="True"
                          SelectionChanged="GridCustom_SelectionChanged"/>
            </TabItem>

        </TabControl>

        <!-- DYNAMIC DETAIL -->
        <DataGrid Grid.Row="3"
              Name="gridDetail"
              AutoGenerateColumns="True"/>

        <!-- Button Action -->
        <StackPanel Grid.Row="4"
            Orientation="Horizontal"
            HorizontalAlignment="Center"
            Margin="0,10">

            <Button Name="btnDbSetting" Width="140" Height="35" Margin="5" Click="BtnDbSetting_Click">
                DB Setting
            </Button>

            <Button Name="btnMigrate" Width="160" Height="35" Margin="5" Click="BtnMigrate_Click">
                Migrate Selected
            </Button>

            <Button Name="btnExportReport" Width="140" Height="35" Margin="5" Click="BtnExportReport_Click">
                Export Report
            </Button>

            <Button Name="ClearScreen" Width="140" Height="35" Margin="5" Click="BtnClearScreen_Click">
                Clear Screen
            </Button>

        </StackPanel>

    </Grid>

</Window>