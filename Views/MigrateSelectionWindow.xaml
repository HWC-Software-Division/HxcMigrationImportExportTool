<Window x:Class="HxcMigrationImportExportTool.Views.MigrateSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HxcMigrationImportExportTool.Views"
        mc:Ignorable="d"
        Title="MigrateSelectionWindow" Height="450" Width="800">

    <!-- DataTemplate for select option -->
    <Window.Resources>
        <!-- PageType -->
        <DataTemplate x:Key="PageTypeTemplate">
            <CheckBox Content="{Binding Data.ClassName}"
              IsChecked="{Binding IsSelected}"
              Margin="5"/>
        </DataTemplate>

        <!-- Resource -->
        <DataTemplate x:Key="ResourceTemplate">
            <CheckBox Content="{Binding Data.Key}"
              IsChecked="{Binding IsSelected}"
              Margin="5"/>
        </DataTemplate>

        <!-- CustomTable -->
        <DataTemplate x:Key="CustomTemplate">
            <CheckBox Content="{Binding Data.TableName}"
              IsChecked="{Binding IsSelected}"
              Margin="5"/>
        </DataTemplate>

    </Window.Resources>
    
    <Grid Margin="10">
        
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0">

            <StackPanel>

                <!-- PageType -->
                <TextBlock Text="PageType" FontWeight="Bold" Margin="0,10,0,5"/>
                <CheckBox Content="Select All" Margin="5" 
                          Checked="PageTypeSelectAll_Checked"
                          Unchecked="PageTypeSelectAll_Checked"/>
                <ItemsControl Name="listPageTypes" ItemTemplate="{StaticResource PageTypeTemplate}"/>
 
                <!-- Resource -->
                <TextBlock Text="ResourceString" FontWeight="Bold" Margin="0,15,0,5"/>
                <CheckBox Content="Select All" Margin="5" 
                          Checked="ResourceStringAll_Checked"
                          Unchecked="ResourceStringAll_Checked"/>
                <ItemsControl Name="listResources" ItemTemplate="{StaticResource ResourceTemplate}"/>

                <!-- Custom -->
                <TextBlock Text="CustomTable" FontWeight="Bold" Margin="0,15,0,5"/>
                <ItemsControl Name="listCustomTable"  ItemTemplate="{StaticResource CustomTemplate}"/>

            </StackPanel>

        </ScrollViewer>

        <!-- Button -->
        <Button Grid.Row="1"
                Content="Migrate"
                Height="40"
                Width="200"
                Click="BtnConfirmMigrate_Click"/>

    </Grid> 

</Window>
