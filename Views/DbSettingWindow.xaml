<Window x:Class="HxcMigrationImportExportTool.Views.DbSettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HxcMigrationImportExportTool.Views"
        mc:Ignorable="d"
        Title="Db Setting Window" Height="450" Width="450">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   Text="Xperience DB Setting"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <!-- Server -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Server"/>
        <TextBox Grid.Row="1" Grid.Column="1" Name="txtServer" Margin="0,20,0,10"/>

        <!-- Database -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Database"/>
        <TextBox Grid.Row="2" Grid.Column="1" Name="txtDatabase" Margin="0,20,0,10"/>

        <!-- Username -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Username"/>
        <TextBox Grid.Row="3" Grid.Column="1" Name="txtUsername" Margin="0,20,0,10"/>

        <!-- Password -->
        <TextBlock Grid.Row="4" Text="Password"/>
        <PasswordBox Grid.Row="4" Name="txtPassword" Margin="0,20,0,10"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,79,0,0">

            <Button Width="120"
                    Margin="5"
                    Click="BtnTest_Click">
                Test Connection
            </Button>

            <Button Width="100"
                    Margin="5"
                    Click="BtnSave_Click">
                Save
            </Button>

            <Button Width="100"
                    Margin="5"
                    Click="BtnClose_Click">
                Close
            </Button>

        </StackPanel>

    </Grid>
</Window>
